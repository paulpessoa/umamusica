# Copy this file to .env and fill in your values

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# App URL (Cloud Run production URL)
APP_URL=https://umamusica-369350924489.us-east1.run.app

# Supabase (Projeto: unamusica)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MercadoPago
ML_TOKEN=your_mercadopago_access_token
ML_P_KEY=your_mercadopago_public_key

# E-mail SMTP (Zoho Mail, Gmail, Brevo, etc.)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_API_KEY=your_16_character_app_specific_password
BREVO_SENDER_EMAIL=exemplo@site.com.br

# Rate limit de custo de IA (teto diário por usuário)
RATE_LIMIT_ENABLED=true            # liga/desliga o teto (false = sem bloqueio)
DAILY_AI_COST_LIMIT_BRL=0.05       # teto de custo de IA por usuário por dia (R$)
USD_TO_BRL=5.5                     # câmbio para converter preços das APIs (USD -> BRL)
WHISPER_COST_PER_CALL_BRL=0.001    # custo fixo estimado por transcrição de voz
# Preços por 1.000.000 de tokens (USD) — conferir com a tabela do provedor
GROQ_INPUT_COST_USD=0.05
GROQ_OUTPUT_COST_USD=0.08
GEMINI_INPUT_COST_USD=0.075
GEMINI_OUTPUT_COST_USD=0.30

# E-mails de admin (separados por vírgula) que recebem alertas
ADMIN_EMAILS=admin@site.com.br

