# Copy this file to .env and fill in your values

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# App URL (Cloud Run production URL)
APP_URL=https://umamusica-369350924489.us-east1.run.app

# Supabase (Projeto: unamusica)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MercadoPago
ML_TOKEN=your_mercadopago_access_token
ML_P_KEY=your_mercadopago_public_key

# E-mail SMTP (Zoho Mail, Gmail, Brevo, etc.)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user@email.com.br
SMTP_PASS=your_16_character_app_specific_password
